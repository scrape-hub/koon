{
  "name": "koonjs",
  "version": "0.7.0",
  "description": "Browser-impersonating HTTP client — TLS, HTTP/2, HTTP/3 fingerprint spoofing. Passes Akamai & Cloudflare. 175 browser profiles.",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "author": "Wedge",
  "repository": {
    "type": "git",
    "url": "https://github.com/scrape-hub/koon.git",
    "directory": "crates/node"
  },
  "homepage": "https://github.com/scrape-hub/koon",
  "bugs": "https://github.com/scrape-hub/koon/issues",
  "engines": {
    "node": ">= 16"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md"
  ],
  "optionalDependencies": {
    "@koonjs/win32-x64-msvc": "0.7.0",
    "@koonjs/linux-x64-gnu": "0.7.0",
    "@koonjs/darwin-arm64": "0.7.0",
    "@koonjs/darwin-x64": "0.7.0"
  },
  "scripts": {
    "build": "cargo build --release -p koon-node && node -e \"require('fs').copyFileSync(require('path').resolve(__dirname,'../../target/release/koon_node.dll'), require('path').resolve(__dirname,'koon.win32-x64-msvc.node'))\"",
    "build:linux": "cargo build --release -p koon-node && cp ../../target/release/libkoon_node.so koon.linux-x64-gnu.node",
    "build:macos": "cargo build --release -p koon-node && cp ../../target/release/libkoon_node.dylib koon.darwin-$(uname -m).node",
    "test": "node ../../test_node.cjs"
  },
  "keywords": [
    "tls-fingerprint",
    "browser-impersonation",
    "http2-fingerprint",
    "anti-bot",
    "web-scraping",
    "akamai",
    "cloudflare",
    "ja3",
    "ja4",
    "http-client",
    "proxy",
    "scraping",
    "stealth",
    "curl-impersonate",
    "boringssl",
    "http3",
    "quic",
    "websocket"
  ]
}
